{
  "dashboard": {
    "title": "Kubernetes 集群概览",
    "tags": ["k8s", "overview"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "集群节点状态",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [{
          "expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"true\"})",
          "legendFormat": "Ready Nodes"
        }]
      },
      {
        "id": 2,
        "title": "Pod 总数",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [{
          "expr": "sum(kube_pod_status_phase{phase=\"Running\"})",
          "legendFormat": "Running Pods"
        }]
      },
      {
        "id": 3,
        "title": "CPU 使用率",
        "type": "gauge",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [{
          "expr": "100 - avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100",
          "legendFormat": "CPU Usage"
        }],
        "fieldConfig": {
          "defaults": {
            "max": 100,
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "red", "value": 85}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "内存使用率",
        "type": "gauge",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [{
          "expr": "(1 - avg(node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "Memory Usage"
        }],
        "fieldConfig": {
          "defaults": {
            "max": 100,
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "red", "value": 85}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "节点 CPU 使用率趋势",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [{
          "expr": "100 - (irate(node_cpu_seconds_total{mode=\"idle\"}[5m]) * 100)",
          "legendFormat": "{{ instance }}"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {"fillOpacity": 10}
          }
        }
      },
      {
        "id": 6,
        "title": "节点内存使用率趋势",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [{
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "{{ instance }}"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {"fillOpacity": 10}
          }
        }
      },
      {
        "id": 7,
        "title": "Pod 状态分布",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
        "targets": [{
          "expr": "sum(kube_pod_status_phase) by (phase)",
          "legendFormat": "{{ phase }}"
        }]
      },
      {
        "id": 8,
        "title": "Namespace 资源使用 Top 10",
        "type": "table",
        "gridPos": {"h": 8, "w": 16, "x": 8, "y": 12},
        "targets": [
          {
            "expr": "sum(container_memory_working_set_bytes{container!=\"\"}) by (namespace)",
            "format": "table",
            "instant": true
          },
          {
            "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\"}[5m])) by (namespace)",
            "format": "table",
            "instant": true
          }
        ]
      }
    ]
  }
}
