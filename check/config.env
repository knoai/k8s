# K8s 集群验收测试配置
# 通过 source 加载，可在执行前覆盖

# ==================== 开关配置 ====================
# 各模块是否执行（true/false）
CHECK_ENV=true
CHECK_NODE=true
CHECK_CORE=true
CHECK_NETWORK=true
CHECK_STORAGE=true
CHECK_SCHEDULING=true
CHECK_SECURITY=true
CHECK_HA=true
CHECK_OPERATOR=true
CHECK_PERFORMANCE=false

# ==================== 超时配置（秒） ====================
TIMEOUT_POD_READY=120
TIMEOUT_DEPLOYMENT_READY=180
TIMEOUT_JOB_COMPLETE=180
TIMEOUT_PVC_BIND=120
TIMEOUT_OPERATOR_CR=300

# ==================== 阈值配置 ====================
# 节点最低 Ready 率（0~1）
NODE_READY_MIN_RATIO=1.0
# apiserver 响应延迟阈值（毫秒）
APISERVER_LATENCY_MS_MAX=500
# etcd 成员最低健康数
ETCD_HEALTHY_MIN=1
# 核心组件 Pod 最低 Ready 率
CORE_POD_READY_MIN_RATIO=1.0

# ==================== Operator 配置 ====================
# Operator Pod 标签选择器，格式: key1=value1,key2=value2
# 若为空则仅检查 CRD 状态，不检查 Operator Pod
OPERATOR_LABELS=""
# Operator 测试 Namespace（默认使用自动生成的测试 NS）
OPERATOR_TEST_NS=""
# 是否执行 CR 生命周期测试（需要用户在 manifests/operator-test/ 放置示例 CR）
OPERATOR_CR_LIFECYCLE_TEST=true

# ==================== 性能测试配置 ====================
# 网络测试并发连接数
PERF_NETWORK_CONNECTIONS=4
# 网络测试持续时间（秒）
PERF_NETWORK_DURATION=10
# 存储测试文件大小
PERF_STORAGE_FILE_SIZE=1G
# 调度压测并发 Pod 数
PERF_SCHEDULING_PODS=50

# ==================== 其他 ====================
# 测试结束后是否自动清理资源
ACCEPTANCE_CLEANUP=true
# 测试 Namespace 前缀
TEST_NS_PREFIX=k8s-acceptance
